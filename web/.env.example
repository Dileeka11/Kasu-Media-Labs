# Base URL the Next server uses to reach the Laravel API (server-side rendering).
API_URL=http://localhost:8000/api

# Base URL the browser uses to reach the Laravel API (e.g. contact form POST).
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# Public origin of this site, used for canonical URLs / sitemap / OG tags.
# In production set this (and the two above) to the live domain before building,
# since the site is a static export (output: 'export').
NEXT_PUBLIC_SITE_URL=http://localhost:3000
